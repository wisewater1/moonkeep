# Moonkeep Elite - Development Environment Configuration
# Copy this file to .env and customize as needed

# Server
MOONKEEP_HOST=0.0.0.0
MOONKEEP_PORT=8001
MOONKEEP_LOG_LEVEL=info

# Database
MOONKEEP_DB_PATH=moonkeep_campaigns.db

# Redis (used by recon-ng job queue)
REDIS_URL=redis://localhost:6379/0

# AI Orchestrator (optional - set your API key for AI features)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Recon-ng
RECON_NG_PATH=./recon-ng/recon-ng

# Frontend dev server
VITE_API_URL=http://localhost:8001
VITE_WS_URL=ws://localhost:8001
