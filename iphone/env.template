# Copy to frontend/.env.local and point it at wherever the Moonkeep
# backend is reachable from the iPhone. Leave blank to use the same
# origin as the frontend (default during `./dev.sh`).

# REST base — no trailing slash, no /api suffix
VITE_API_URL=

# WebSocket base — use wss:// if your ingress does TLS
VITE_WS_URL=
